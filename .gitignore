# Build output
/target
# The tb-vmm crate (Firecracker-baseline harness) has its own target dir.
/tb-vmm/target

# QEMU serial capture logs produced by the M0 DoD assertion (BUILD.md)
/serial-*.log
/*.serial.log

# Editor / OS cruft
*.rs.bk
*.swp
*~
.DS_Store
Thumbs.db

# Local cargo overrides that should not be shared
.cargo/config.local.toml

# NOTE: Cargo.lock is committed on purpose — this workspace builds binaries and
# we want reproducible boot images.

# The M30 xport-harness host tool (its own nested workspace) has its own target
# dir; the generalization covers any future nested-workspace tool the same way.
/tools/xport-harness/target
/tools/*/target

# Scratch files from the PR workflow (never commit these)
*.pr-body.md
*.scratch.md

# Raw research source material (PDFs and text extractions) cited by
# docs/research/*; kept locally, re-downloadable from the URLs cited there.
/docs/research/sources/
