# The project identity — THE single source of truth for the build identifiers
# at the script level. The Rust-side single source of truth is
# crates/brand/src/lib.rs (every wire/witness byte derives from it); the BRAND
# and NOTE_TYPE_HEX values below MIRROR that crate for shell/CI guards that
# cannot import Rust. To rename the project: edit crates/brand/src/lib.rs +
# THIS file (+ the mirrored workflow env: blocks + package/target names);
# everything else derives. Every scripts/*.sh sources this file and uses the
# variables instead of literals.
#
# CI workflows cannot cheaply source a file inside `${{ }}` path expressions,
# so each .github/workflows/*.yml defines the SAME values once in a top-level
# `env:` block that MIRRORS this file — a rename changes this file and those
# env: blocks together (grep for "mirrors scripts/project.env").
PROJECT_NAME=yuva
KERNEL_BIN=yuva-kernel
TARGET_X86=x86_64-yuva-none
TARGET_A64=aarch64-yuva-none
# The brand WIRE constants (mirror crates/brand: brand_upper!() and
# NOTE_TYPE_ENTRY64) — used by the bench.yml nano-guest note-grep guard, which
# pins the .S mirror in bench/nano-guest/nano-guest.S to the brand crate.
BRAND=YUVA
NOTE_TYPE_HEX=0x59550001
